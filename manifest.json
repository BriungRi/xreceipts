{
  "manifest_version": 3,
  "name": "X Receipts",
  "version": "0.1.0",
  "description": "Save tweet receipts with screenshots and searchable text.",
  "permissions": ["downloads", "storage", "tabs", "scripting"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "X Receipts",
    "default_popup": "src/search.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
